# Browser-safe Supabase variables (recommended; server fallback is also supported)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY
VITE_SUPABASE_BUCKET=apex-files

# Server-only Supabase variables
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SECRET_KEY=YOUR_ROTATED_SUPABASE_SECRET_KEY
# SUPABASE_SERVICE_ROLE_KEY is also accepted as an alternative name.
SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY
SUPABASE_BUCKET=apex-files

# Firebase Admin SDK server variables
FIREBASE_PROJECT_ID=theapexchemistry
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@theapexchemistry.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"
ADMIN_UID=Y7hWLggcPsY36p8mfmBqbMligSD3

# Vercel cron protection
CRON_SECRET=REPLACE_WITH_A_LONG_RANDOM_VALUE
