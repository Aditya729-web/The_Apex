# Public Supabase settings
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Server-only Supabase key. Never expose this key in browser code.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Public production URL used in generated credential messages.
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# Vercel Cron protection. Add the same value as CRON_SECRET in Vercel.
CRON_SECRET=replace-with-a-long-random-secret

# Optional automatic WhatsApp fee reminders using Meta WhatsApp Cloud API.
# Without these variables, the system still creates in-app reminders.
WHATSAPP_GRAPH_VERSION=v23.0
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE_NAME=monthly_fee_reminder
WHATSAPP_TEMPLATE_LANGUAGE=en_US
