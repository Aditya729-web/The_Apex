rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function admin() { return signedIn() && request.auth.uid == "Y7hWLggcPsY36p8mfmBqbMligSD3"; }
    function self(uid) { return signedIn() && request.auth.uid == uid; }

    match /students/{uid} { allow read: if admin() || self(uid); allow write: if admin(); }
    match /batches/{id} { allow read: if signedIn(); allow write: if admin(); }
    match /fees/{id} { allow read: if admin() || (signedIn() && resource.data.studentUid == request.auth.uid); allow write: if admin(); }
    match /notes/{id} { allow read: if signedIn(); allow write: if admin(); }
    match /notifications/{id} { allow read: if signedIn(); allow write: if admin(); }
    match /doubts/{id} {
      allow create: if signedIn() && request.resource.data.studentUid == request.auth.uid;
      allow read: if admin() || (signedIn() && resource.data.studentUid == request.auth.uid);
      allow update, delete: if admin();
    }
    match /metadata/{id} { allow read, write: if admin(); }
    match /automationRuns/{id} { allow read, write: if admin(); }
  }
}
