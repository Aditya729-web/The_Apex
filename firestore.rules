rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the user is authenticated as an admin
    function isAdmin() {
      return request.auth != null; 
    }
    
    // Students Collection
    match /students/{studentId} {
      allow read: if true; 
      allow write: if isAdmin();
    }
    
    // Batches Collection
    match /batches/{batchId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Fee Records Collection
    match /feeRecords/{recordId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Notes Collection
    match /notes/{noteId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Note Files (Chunks) Collection
    match /note_files/{fileId} {
      allow read: if true;
      allow write: if isAdmin();
      
      match /chunks/{chunkId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }
    
    // Doubts Collection
    match /doubts/{doubtId} {
      allow read: if true;
      allow create: if true; // Students can create doubts
      allow update, delete: if isAdmin();
    }
    
    // Tests Collection
    match /tests/{testId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Notifications Collection
    match /notifications/{notificationId} {
      allow read: if true;
      allow write: if true; // Both students and admins can update read status
    }
  }
}
