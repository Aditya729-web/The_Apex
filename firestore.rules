rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isAdmin() { return signedIn() && request.auth.uid == 'Y7hWLggcPsY36p8mfmBqbMligSD3'; }
    function isStudent(uid) { return signedIn() && request.auth.uid == uid; }

    match /students/{uid} {
      allow read: if isAdmin() || isStudent(uid);
      allow create, update, delete: if isAdmin();
    }
    match /batches/{batchId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }
    match /notes/{noteId} {
      allow read: if isAdmin() || (signedIn() && resource.data.batchId == get(/databases/$(database)/documents/students/$(request.auth.uid)).data.batchId);
      allow create, update, delete: if isAdmin();
    }
    match /fees/{feeId} {
      allow read: if isAdmin() || (signedIn() && resource.data.studentUid == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }
    match /notifications/{notificationId} {
      allow read: if isAdmin() || (signedIn() && resource.data.studentUid == request.auth.uid);
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (signedIn() && resource.data.studentUid == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']));
    }
  }
}
